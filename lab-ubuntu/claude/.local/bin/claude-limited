#!/usr/bin/env bash
set -euo pipefail

if ! CLAUDE_BIN="$(command -v claude)"; then
    echo "claude-limited: 'claude' not found on PATH" >&2
    exit 1
fi

exec systemd-run --user --scope \
    --same-dir \
    --collect \
    -p MemoryAccounting=yes \
    -p MemoryHigh=160G \
    -p MemoryMax=180G \
    -p MemorySwapMax=4G \
    "$CLAUDE_BIN" "$@"
